<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.malllease.controller.ClientShowingsController"
            styleClass="showings-screen">

    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="showings-header">
            <Label text="Мои показы" styleClass="heading-3"/>
            <Label fx:id="totalCountLabel" text="0" styleClass="point-count-badge"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Обновить" onAction="#handleRefresh" styleClass="btn-secondary"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="showing-list-scroll">
            <content>
                <VBox spacing="10" styleClass="client-showings-list">
                    <Label fx:id="emptyLabel"
                           text="У вас пока нет запрошенных показов. Выберите свободную точку на карте и нажмите «Запросить показ»."
                           styleClass="inspector-empty" wrapText="true"
                           visible="true" managed="true"/>
                    <VBox fx:id="showingListBox" spacing="10"/>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
