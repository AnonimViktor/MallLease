<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.malllease.controller.AuthController"
           prefWidth="1180" prefHeight="760" stylesheets="@../css/styles.css"
           styleClass="auth-shell">

    <HBox fx:id="authContent" styleClass="auth-layout">
        <VBox styleClass="auth-visual-panel" spacing="22"
              HBox.hgrow="ALWAYS" minWidth="380">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="M" styleClass="auth-brand-mark"/>
                <VBox spacing="1">
                    <Label text="MallLease" styleClass="auth-brand-title"/>
                    <Label text="управление арендой торговых площадей" styleClass="auth-brand-caption"/>
                </VBox>
            </HBox>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="12" maxWidth="520">
                <Label text="Интерактивная карта ТЦ, договоры и платежи в одном рабочем окне."
                       styleClass="auth-hero-title" wrapText="true"/>
                <Label text="Клиенты выбирают торговые точки и запрашивают показ, менеджеры ведут договоры и контролируют финансовую сторону аренды."
                       styleClass="auth-hero-copy" wrapText="true"/>
            </VBox>

            <HBox spacing="10" styleClass="auth-proof-row">
                <VBox styleClass="auth-proof-card" spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="2" styleClass="auth-proof-value"/>
                    <Label text="торговых центра" styleClass="auth-proof-label"/>
                </VBox>
                <VBox styleClass="auth-proof-card" spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="49" styleClass="auth-proof-value"/>
                    <Label text="торговых точек" styleClass="auth-proof-label"/>
                </VBox>
                <VBox styleClass="auth-proof-card" spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="BCNF" styleClass="auth-proof-value"/>
                    <Label text="модель данных" styleClass="auth-proof-label"/>
                </VBox>
            </HBox>
        </VBox>

        <StackPane styleClass="auth-form-zone" HBox.hgrow="ALWAYS">
            <VBox fx:id="loginPane" styleClass="auth-card" spacing="18" maxWidth="520">
                <VBox spacing="5">
                    <Label text="Вход" styleClass="auth-form-title"/>
                    <Label text="Введите учетные данные, чтобы продолжить работу."
                           styleClass="auth-form-subtitle" wrapText="true"/>
                </VBox>

                <VBox spacing="7">
                    <Label text="Логин" styleClass="field-label"/>
                    <TextField fx:id="loginField" promptText="admin / manager / client" prefHeight="44"/>
                    <Label fx:id="loginError" styleClass="error-label" visible="false" managed="false"/>
                </VBox>

                <VBox spacing="7">
                    <Label text="Пароль" styleClass="field-label"/>
                    <PasswordField fx:id="passwordField" promptText="Введите пароль" prefHeight="44"/>
                    <Label fx:id="passwordError" styleClass="error-label" visible="false" managed="false"/>
                </VBox>

                <Label fx:id="generalError" styleClass="error-label" visible="false" managed="false" wrapText="true"/>

                <Button text="Войти" onAction="#handleLogin" styleClass="btn-primary, auth-main-button"
                        maxWidth="Infinity"/>

                <HBox alignment="CENTER" spacing="8">
                    <Label text="Нет аккаунта?" styleClass="text-secondary"/>
                    <Button text="Создать профиль клиента" onAction="#handleShowRegister"
                            styleClass="link-button"/>
                </HBox>
            </VBox>

            <VBox fx:id="registerPane" styleClass="auth-card" spacing="14" maxWidth="540"
                  visible="false" managed="false">
                <VBox spacing="5">
                    <Label text="Регистрация клиента" styleClass="auth-form-title"/>
                    <Label text="Создайте учетную запись арендатора. После регистрации вход будет выполнен автоматически."
                           styleClass="auth-form-subtitle" wrapText="true"/>
                </VBox>

                <VBox spacing="12">
                            <HBox spacing="10">
                                <VBox spacing="7" HBox.hgrow="ALWAYS">
                                    <Label text="ФИО" styleClass="field-label"/>
                                    <TextField fx:id="regFullNameField" promptText="Иванов Иван Иванович"/>
                                </VBox>
                                <VBox spacing="7" HBox.hgrow="ALWAYS">
                                    <Label text="Логин" styleClass="field-label"/>
                                    <TextField fx:id="regLoginField" promptText="client_login"/>
                                </VBox>
                            </HBox>

                            <HBox spacing="10">
                                <VBox spacing="7" HBox.hgrow="ALWAYS">
                                    <Label text="Email" styleClass="field-label"/>
                                    <TextField fx:id="regEmailField" promptText="client@example.com"/>
                                </VBox>
                                <VBox spacing="7" HBox.hgrow="ALWAYS">
                                    <Label text="Телефон" styleClass="field-label"/>
                                    <TextField fx:id="regPhoneField" promptText="+7..."/>
                                </VBox>
                            </HBox>

                            <HBox spacing="10">
                                <VBox spacing="7" HBox.hgrow="ALWAYS">
                                    <Label text="Пароль" styleClass="field-label"/>
                                    <PasswordField fx:id="regPasswordField" promptText="Aa123456!"/>
                                </VBox>
                                <VBox spacing="7" HBox.hgrow="ALWAYS">
                                    <Label text="Повтор пароля" styleClass="field-label"/>
                                    <PasswordField fx:id="regPasswordRepeatField" promptText="Повторите пароль"/>
                                </VBox>
                            </HBox>
                            <Label fx:id="passwordHintLabel"
                                   text="Минимум 8 символов, заглавная буква, цифра и спецсимвол."
                                   styleClass="auth-hint" wrapText="true"/>

                            <VBox spacing="7">
                                <Label text="Компания" styleClass="field-label"/>
                                <TextField fx:id="regCompanyField" promptText="ООО «Компания»"/>
                            </VBox>

                            <VBox spacing="7">
                                <Label text="Юридический адрес" styleClass="field-label"/>
                                <TextField fx:id="regAddressField" promptText="Адрес компании"/>
                            </VBox>

                            <VBox spacing="7">
                                <Label text="Реквизиты" styleClass="field-label"/>
                                <TextField fx:id="regBankDetailsField" promptText="ИНН, р/с, банк"/>
                            </VBox>
                </VBox>

                <Label fx:id="regGeneralError" styleClass="error-label" visible="false" managed="false" wrapText="true"/>

                <Button text="Создать аккаунт" onAction="#handleRegister"
                        styleClass="btn-primary, auth-main-button" maxWidth="Infinity"/>

                <HBox alignment="CENTER" spacing="8">
                    <Label text="Уже есть аккаунт?" styleClass="text-secondary"/>
                    <Button text="Вернуться ко входу" onAction="#handleShowLogin" styleClass="link-button"/>
                </HBox>
            </VBox>
        </StackPane>
    </HBox>

    <VBox fx:id="authLoadingOverlay" styleClass="auth-loading-overlay" alignment="CENTER" spacing="14">
        <Label text="M" styleClass="auth-loading-mark"/>
        <Label text="MallLease" styleClass="auth-loading-title"/>
        <Label text="Загружаем рабочее пространство" styleClass="auth-loading-caption"/>
    </VBox>
</StackPane>
