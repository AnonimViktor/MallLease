<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.malllease.controller.MapController"
            styleClass="map-screen, map-overlay-root">

    <StackPane fx:id="mapStage" styleClass="map-stage"
               AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
               AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <Pane fx:id="mapPane" styleClass="map-pane">
            <Canvas fx:id="mapCanvas" width="900" height="600"/>
        </Pane>
    </StackPane>

    
    <HBox styleClass="floating-card, map-top-bar" spacing="10" alignment="CENTER_LEFT"
          pickOnBounds="false"
          AnchorPane.topAnchor="18" AnchorPane.leftAnchor="20">
        <ImageView fx:id="centerImageView" fitWidth="34" fitHeight="34" pickOnBounds="true"
                   styleClass="center-thumb"/>
        <ComboBox fx:id="centerComboBox" prefWidth="220" onAction="#handleCenterChange"
                  styleClass="map-center-combo"/>
        <ComboBox fx:id="floorComboBox" prefWidth="120"
                  styleClass="map-floor-combo" promptText="Этаж"/>
    </HBox>

    <HBox fx:id="searchBar" styleClass="floating-card, search-bar" spacing="0" alignment="CENTER_LEFT"
          pickOnBounds="false" prefWidth="460" maxWidth="460"
          AnchorPane.topAnchor="18">
        <StackPane styleClass="search-icon-box">
            <FontIcon iconLiteral="fth-search" styleClass="search-mag"/>
        </StackPane>
        <TextField fx:id="pointSearchField" promptText="Поиск точки по коду или статусу"
                   styleClass="search-input-flat" HBox.hgrow="ALWAYS"/>
    </HBox>

    <VBox fx:id="searchResultsCard" styleClass="floating-card, search-results-card"
          visible="false" managed="false"
          pickOnBounds="false" prefWidth="460" maxWidth="460"
          AnchorPane.topAnchor="72">
        <ScrollPane fx:id="searchResultsScroll" fitToWidth="true" hbarPolicy="NEVER"
                    styleClass="search-results-scroll" maxHeight="280">
            <content>
                <VBox fx:id="searchResultsBox" spacing="6" styleClass="search-results-box"/>
            </content>
        </ScrollPane>
    </VBox>

    <VBox fx:id="noMapPanel" styleClass="floating-card, no-map-page" spacing="14"
          visible="false" managed="false"
          AnchorPane.topAnchor="90" AnchorPane.leftAnchor="360"
          AnchorPane.rightAnchor="400" AnchorPane.bottomAnchor="20">
        <HBox spacing="14" alignment="CENTER_LEFT">
            <ImageView fx:id="noMapHeaderImage" fitWidth="120" fitHeight="80" pickOnBounds="true"
                       styleClass="point-photo"/>
            <VBox spacing="2">
                <Label fx:id="noMapCenterName" text="" styleClass="card-title"/>
                <Label text="У этого ТЦ нет интерактивной карты — список точек этажа ниже"
                       styleClass="no-map-sub" wrapText="true"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="noMapCountLabel" text="0" styleClass="point-count-badge"/>
        </HBox>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="point-list-scroll"
                    VBox.vgrow="ALWAYS">
            <content>
                <VBox fx:id="noMapListBox" spacing="10"/>
            </content>
        </ScrollPane>
    </VBox>

    <VBox fx:id="leftPanel" spacing="14" pickOnBounds="false" prefWidth="320" maxWidth="320"
          AnchorPane.topAnchor="90" AnchorPane.leftAnchor="20">

        <VBox styleClass="floating-card, filters-card" spacing="14">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="Фильтры" styleClass="card-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="filterResultLabel" text="" styleClass="filter-result-label"/>
            </HBox>

            <VBox styleClass="slider-block, slider-block-price" spacing="6">
                <Label text="Цена, ₽/день" styleClass="slider-block-title"/>
                <HBox fx:id="priceRangeContainer" minHeight="32"/>
            </VBox>

            <VBox styleClass="slider-block, slider-block-area" spacing="6">
                <Label text="Площадь, м²" styleClass="slider-block-title"/>
                <HBox fx:id="areaRangeContainer" minHeight="32"/>
            </VBox>

            <VBox styleClass="slider-block, slider-block-availability" spacing="6">
                <Label text="Доступна в период" styleClass="slider-block-title"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <DatePicker fx:id="availFromPicker" prefWidth="135" promptText="с"/>
                    <Label text="—" styleClass="step-caption"/>
                    <DatePicker fx:id="availToPicker" prefWidth="135" promptText="по"/>
                </HBox>
                <Label fx:id="availabilityHintLabel" text="" styleClass="slot-hint-inline" wrapText="true"/>
            </VBox>

            <VBox spacing="10">
                <HBox fx:id="statusDropdownContainer" alignment="CENTER_LEFT" maxWidth="Infinity"/>
                <CheckBox fx:id="acOnlyCheckBox" text="Только с кондиционером"
                          styleClass="map-filter-check" maxWidth="Infinity"/>
                <Button fx:id="resetFiltersButton" text="Сбросить фильтры"
                        onAction="#handleResetFilters"
                        styleClass="btn-secondary, map-reset-button" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </VBox>

    <VBox fx:id="rightColumn" spacing="14" pickOnBounds="false" prefWidth="360" maxWidth="360"
          AnchorPane.topAnchor="18" AnchorPane.rightAnchor="22" AnchorPane.bottomAnchor="100">

        <VBox fx:id="pointInfoCard" styleClass="floating-card, point-inspector" spacing="16">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="Торговая точка" styleClass="card-title"/>
                <Label fx:id="pointCodeLabel" text="—" styleClass="point-code-badge"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button styleClass="inspector-close-button, icon-button" onAction="#handleClosePointInfo">
                    <graphic><FontIcon iconLiteral="fth-x"/></graphic>
                </Button>
            </HBox>

            <Label fx:id="inspectorEmptyLabel" text="Выберите точку на карте или через поиск сверху."
                   styleClass="inspector-empty" wrapText="true"/>

            <VBox fx:id="pointDetailsBox" spacing="12" visible="false" managed="false">
                <ImageView fx:id="pointImageView" fitWidth="316" fitHeight="170" pickOnBounds="true"
                           styleClass="point-photo"/>
                <HBox styleClass="inspector-row">
                    <Label text="Этаж" styleClass="inspector-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="pointFloorLabel" text="—" styleClass="inspector-value"/>
                </HBox>
                <HBox styleClass="inspector-row">
                    <Label text="Площадь" styleClass="inspector-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="pointAreaLabel" text="—" styleClass="inspector-value"/>
                </HBox>
                <HBox styleClass="inspector-row">
                    <Label text="Кондиционер" styleClass="inspector-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="pointAcLabel" text="—" styleClass="inspector-value"/>
                </HBox>
                <HBox styleClass="inspector-row">
                    <Label text="Статус" styleClass="inspector-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="pointStatusLabel" text="—" styleClass="status-free"/>
                </HBox>
                <HBox styleClass="inspector-row">
                    <Label text="Стоимость за день" styleClass="inspector-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="pointRateLabel" text="—" styleClass="inspector-value"/>
                </HBox>

                <VBox styleClass="period-summary" spacing="6">
                    <Label text="Примерная стоимость за период" styleClass="period-caption"/>
                    <Label fx:id="periodPriceLabel" text="—" styleClass="period-price"/>
                </VBox>

                <VBox fx:id="existingShowingBox" styleClass="existing-showing-card" spacing="8"
                      visible="false" managed="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="Показ уже запрошен" styleClass="period-caption"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="existingShowingStatusBadge" text="" styleClass="showing-status-requested"/>
                    </HBox>
                    <HBox styleClass="inspector-row">
                        <Label text="Дата и время" styleClass="inspector-label"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="existingShowingDateLabel" text="—" styleClass="inspector-value"/>
                    </HBox>
                    <Label fx:id="existingShowingCommentLabel" text="" styleClass="slot-hint" wrapText="true"/>
                </VBox>

                <VBox fx:id="showingSchedulerBox" styleClass="showing-slot-card" spacing="9"
                      visible="false" managed="false">
                    <Label text="Выберите свободный слот показа" styleClass="period-caption"/>
                    <HBox spacing="8">
                        <DatePicker fx:id="showingDatePicker" prefWidth="150"/>
                        <ComboBox fx:id="showingSlotBox" prefWidth="150" promptText="Время"/>
                    </HBox>
                    <Label fx:id="showingSlotHintLabel" text="" styleClass="slot-hint" wrapText="true"/>
                </VBox>

                <Button fx:id="requestShowingButton" text="Запросить показ"
                        styleClass="btn-primary" maxWidth="Infinity" onAction="#handleRequestShowing"/>
                <Label fx:id="showingFeedbackLabel" text="" styleClass="showing-feedback-label"
                       wrapText="true" visible="false" managed="false"/>
            </VBox>
        </VBox>

    </VBox>

    <HBox fx:id="bottomBar" styleClass="floating-card, map-bottom-bar" spacing="14" alignment="CENTER"
          pickOnBounds="false"
          AnchorPane.bottomAnchor="20">
        <Button onAction="#handleZoomOut" styleClass="map-tool-button, icon-button">
            <graphic><FontIcon iconLiteral="fth-minus"/></graphic>
        </Button>
        <Label fx:id="zoomLabel" text="100%" styleClass="zoom-pct-label-inline"/>
        <Button onAction="#handleZoomIn" styleClass="map-tool-button, icon-button">
            <graphic><FontIcon iconLiteral="fth-plus"/></graphic>
        </Button>
        <Button onAction="#handleZoomReset" styleClass="map-tool-button, icon-button">
            <graphic><FontIcon iconLiteral="fth-rotate-ccw"/></graphic>
        </Button>
        <Region styleClass="vertical-divider"/>
        <HBox spacing="6" alignment="CENTER_LEFT">
            <Region styleClass="legend-dot, legend-dot-free"/>
            <Label text="Свободно" styleClass="legend-label"/>
        </HBox>
        <HBox spacing="6" alignment="CENTER_LEFT">
            <Region styleClass="legend-dot, legend-dot-occupied"/>
            <Label text="Занято" styleClass="legend-label"/>
        </HBox>
        <HBox spacing="6" alignment="CENTER_LEFT">
            <Region styleClass="legend-dot, legend-dot-unavailable"/>
            <Label text="Недоступно" styleClass="legend-label"/>
        </HBox>
        <HBox spacing="6" alignment="CENTER_LEFT">
            <Region styleClass="legend-dot, legend-dot-selected"/>
            <Label text="Выбрано" styleClass="legend-label"/>
        </HBox>
        <HBox spacing="6" alignment="CENTER_LEFT">
            <Region styleClass="legend-dot, legend-dot-self"/>
            <Label text="Ваша" styleClass="legend-label"/>
        </HBox>
        <HBox spacing="6" alignment="CENTER_LEFT">
            <Region styleClass="legend-dot, legend-dot-expiring"/>
            <Label text="Истекает" styleClass="legend-label"/>
        </HBox>
    </HBox>
</AnchorPane>
